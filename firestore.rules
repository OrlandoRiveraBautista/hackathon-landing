rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidSex(sex) {
      return sex in ['male', 'female', 'other', 'preferNotToSay'];
    }

    function isValidShirtSize(size) {
      return size in ['XS', 'S', 'M', 'L', 'XL', 'XXL'];
    }

    function isOptionalString(field) {
      return !(field in request.resource.data) || request.resource.data[field] is string;
    }

    function waitlistCoreFieldsUnchanged() {
      return request.resource.data.name == resource.data.name
          && request.resource.data.email == resource.data.email
          && request.resource.data.phone == resource.data.phone
          && request.resource.data.age == resource.data.age
          && request.resource.data.sex == resource.data.sex
          && request.resource.data.createdAt == resource.data.createdAt
          && (!('school' in resource.data) || request.resource.data.school == resource.data.school)
          && (!('shirtSize' in resource.data) || request.resource.data.shirtSize == resource.data.shirtSize)
          && (!('github' in resource.data) || request.resource.data.github == resource.data.github)
          && (!('interests' in resource.data) || request.resource.data.interests == resource.data.interests);
    }

    function isOnSiteBoostUpdate() {
      return waitlistCoreFieldsUnchanged()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onSiteInterested', 'onSiteInterestedAt'])
          && request.resource.data.onSiteInterested == true
          && (!('onSiteInterested' in resource.data) || resource.data.onSiteInterested != true);
    }

    function onsiteTapCountBefore() {
      return ('onSiteBoostTapCount' in resource.data && resource.data.onSiteBoostTapCount is int)
        ? resource.data.onSiteBoostTapCount
        : 0;
    }

    function isOnSiteTapUpdate() {
      return waitlistCoreFieldsUnchanged()
          && request.resource.data.onSiteBoostTapCount is int
          && onsiteTapCountBefore() < 1000
          && request.resource.data.onSiteBoostTapCount == onsiteTapCountBefore() + 1
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onSiteBoostTapCount'])
            ||
            (
              request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onSiteInterested', 'onSiteInterestedAt', 'onSiteBoostTapCount'])
              && request.resource.data.onSiteInterested == true
              && (!('onSiteInterested' in resource.data) || resource.data.onSiteInterested != true)
            )
          );
    }

    function isShirtSizeUpdate() {
      return waitlistCoreFieldsUnchanged()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shirtSize'])
          && request.resource.data.shirtSize is string
          && isValidShirtSize(request.resource.data.shirtSize);
    }

    function isOnSiteStatusUpdate() {
      return waitlistCoreFieldsUnchanged()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onSiteStatus', 'onSiteSelectedAt'])
          && request.resource.data.onSiteStatus in ['selected', 'remote', 'pending'];
    }

    function isOnSiteResetUpdate() {
      return waitlistCoreFieldsUnchanged()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['onSiteStatus', 'onSiteSelectedAt'])
          && request.resource.data.onSiteStatus == 'pending'
          && !('onSiteSelectedAt' in request.resource.data);
    }

    match /waitlist/{emailId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'phone', 'age', 'sex', 'shirtSize', 'status', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() >= 2
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() >= 10
                    && request.resource.data.phone.size() <= 15
                    && request.resource.data.age is int
                    && request.resource.data.age >= 18
                    && request.resource.data.age <= 120
                    && request.resource.data.sex is string
                    && isValidSex(request.resource.data.sex)
                    && request.resource.data.shirtSize is string
                    && isValidShirtSize(request.resource.data.shirtSize)
                    && request.resource.data.status == 'pending'
                    && isOptionalString('school')
                    && isOptionalString('github')
                    && isOptionalString('interests');
      allow read: if true;
      allow update: if (
                      waitlistCoreFieldsUnchanged()
                      && (
                        (
                          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'contactedAt'])
                          && request.resource.data.status == 'contacted'
                        )
                        ||
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['platformNotifiedAt'])
                      )
                    )
                    || isOnSiteBoostUpdate()
                    || isOnSiteTapUpdate()
                    || isShirtSizeUpdate()
                    || isOnSiteStatusUpdate()
                    || isOnSiteResetUpdate();
      allow delete: if false;
    }

    match /config/onsite-selection {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    match /sponsors/{emailId} {
      allow create: if request.resource.data.keys().hasAll([
                      'name', 'email', 'phone', 'company',
                      'sponsorship', 'problem', 'wantsWorkshop', 'createdAt'
                    ])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() >= 2
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.phone is string
                    && request.resource.data.phone.size() >= 10
                    && request.resource.data.phone.size() <= 15
                    && request.resource.data.company is string
                    && request.resource.data.company.size() >= 2
                    && request.resource.data.sponsorship is string
                    && request.resource.data.sponsorship.size() >= 3
                    && request.resource.data.problem is string
                    && request.resource.data.problem.size() >= 3
                    && request.resource.data.wantsWorkshop is bool;
      allow read: if true;
      allow update, delete: if false;
    }
  }
}
